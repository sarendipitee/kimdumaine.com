---
import Layout from "../layouts/Layout.astro";
import OfferingCard from "../components/OfferingCard.astro";
import { offerings } from "../data/offerings";
---
<Layout
  title="Consultations & Offerings — Kimberly Dumaine"
  description="Explore the private and group consultations Kim offers — life assessment readings, trance sessions with Dr. Peebles, spiritual counseling, career guidance, house blessings, and animal communication."
>
  <section class="page-hero">
    <div class="container">
      <span class="section-kicker center">Ways to Work Together</span>
      <h1>Consultations &amp; <em>Offerings</em></h1>
      <p>Thought-provoking, life-changing sessions tailored to your path.</p>
    </div>
  </section>

  <main>
    <section class="page-content">
      <div class="container">
        <div class="prose">
          <p>
            Scheduling a session with Kim can be an important part of your spiritual
            development, providing you with a wonderful opportunity to increase your
            awareness and understand the power that you possess to change any element in
            your life. With Kim&rsquo;s unique abilities, she will help bring to your
            conscious awareness the beliefs and choices that are creating your current
            life experiences.
          </p>
          <p>
            Many types of sessions are available, depending on your specific needs, and can
            be scheduled at your convenience, by appointment only. You can expect a frank,
            down-to-earth approach to your questions and concerns, mixed with a healthy
            dose of good-natured humor and light-heartedness.
          </p>
        </div>

        <div class="type-grid">
          {offerings.map((o) => (
            <OfferingCard icon={o.icon} title={o.title} copy={o.copy} />
          ))}
        </div>

        <p class="prose" style="margin-top: 40px; text-align: center; color: var(--text-dim);">
          Gift certificates are available for any of the above sessions upon request.
        </p>

        <div class="page-cta">
          <a href={`${import.meta.env.BASE_URL}request-a-session/`} class="btn btn-glow">Request a Private Session</a>
        </div>
      </div>
    </section>
  </main>
</Layout>
