---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import portrait from "../assets/kim-portrait.jpg";
---
<Layout
  title="Kimberly Dumaine — Psychic Medium, Spiritual Counselor &amp; Trance Channel"
  description="Kimberly Dumaine is a gifted psychic medium, spiritual counselor, and trance channel for Dr. James Martin Peebles, serving clients in Scottsdale, Arizona and worldwide for over 30 years."
>
  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="hero" id="top">
    <canvas id="cosmos" aria-hidden="true"></canvas>
    <div class="hero-veil" aria-hidden="true"></div>

    <div class="hero-content">
      <p class="hero-kicker reveal">Psychic Medium&ensp;·&ensp;Spiritual Counselor&ensp;·&ensp;Trance Channel</p>
      <h1 class="hero-name reveal">Kimberly <em>Dumaine</em></h1>
      <div class="hero-rule reveal" aria-hidden="true"><span>✦</span></div>
      <p class="hero-question reveal">“Are you ready to wake up and remember?”</p>
      <p class="hero-sub reveal">
        For over thirty years, Kim has bridged the seen and unseen worlds —
        offering insight, healing, and messages from spirit to guide you
        home to your own greatness.
      </p>
      <div class="hero-actions reveal">
        <a href="#offerings" class="btn btn-glow">Begin Your Journey</a>
        <a href="#peebles" class="btn btn-ghost">Explore Trance Sessions</a>
      </div>
    </div>

    <a class="scroll-hint" href="#about" aria-label="Scroll to learn more">
      <span class="scroll-hint-line"></span>
    </a>
  </section>

  <main>
    <!-- ═══════════════ WELCOME ═══════════════ -->
    <section class="welcome" id="about">
      <div class="container welcome-grid">
        <div class="welcome-copy reveal">
          <p class="section-kicker">Welcome, Beautiful Soul</p>
          <h2>The answers have always been <em>within you</em> — waiting to be revealed.</h2>
          <p>
            Kimberly Dumaine, a highly gifted and respected intuitive, psychic medium,
            spiritual counselor, and metaphysical teacher, has been sharing insights
            and messages from spirit with clients for over three decades. From her
            private practice in Scottsdale, Arizona, she serves seekers locally,
            nationally, and abroad — in person, by phone, and online.
          </p>
          <p>
            Her belief, demonstrated clearly in every session: spirit communication is
            not only possible, but essential to our quest for expanded consciousness.
            Everyone and everything is interconnected — and we can learn to touch one
            another's energy in consciously positive ways.
          </p>
          <a href={`${import.meta.env.BASE_URL}about-kim/`} class="text-link">Read Kim's full story <span aria-hidden="true">→</span></a>
        </div>
        <div class="welcome-aside reveal">
          <figure class="portrait-frame">
            <Image src={portrait} alt="Kimberly Dumaine smiling outdoors" width={1600} height={2000} loading="lazy" />
            <figcaption>
              <span class="portrait-name">Kimberly Dumaine</span>
              <span class="portrait-title">Trance&nbsp;Medium · Reiki&nbsp;Master · Hypnotherapist · Animal&nbsp;Communicator</span>
            </figcaption>
          </figure>
          <p class="portrait-meta">
            <span>30<sup>+</sup> Years in Spirit's Service</span>
            <span aria-hidden="true">✦</span>
            <span>Scottsdale, AZ — worldwide by phone &amp; online</span>
          </p>
        </div>
      </div>
    </section>

    <!-- ═══════════════ OFFERINGS ═══════════════ -->
    <section class="offerings" id="offerings">
      <div class="container">
        <p class="section-kicker center reveal">Ways to Work Together</p>
        <h2 class="section-title center reveal">Consultations &amp; <em>Offerings</em></h2>
        <div class="card-grid">
          <a href={`${import.meta.env.BASE_URL}consultations/`} class="offer-card reveal">
            <span class="offer-glyph" aria-hidden="true">☽</span>
            <h3>Life Assessment Sessions</h3>
            <p>A clairvoyant reading of where you stand — illuminating patterns, blocks, and the many paths open before you.</p>
            <span class="card-link">Learn more <span aria-hidden="true">→</span></span>
          </a>
          <a href={`${import.meta.env.BASE_URL}consultations/`} class="offer-card offer-card-featured reveal">
            <span class="offer-glyph" aria-hidden="true">✧</span>
            <h3>Trance Sessions with Dr.&nbsp;Peebles</h3>
            <p>Speak directly with the spirit of Dr. James Martin Peebles as he answers through Kim in deep trance. Private &amp; group sessions.</p>
            <span class="card-link">Learn more <span aria-hidden="true">→</span></span>
          </a>
          <a href={`${import.meta.env.BASE_URL}consultations/`} class="offer-card reveal">
            <span class="offer-glyph" aria-hidden="true">❋</span>
            <h3>Spiritual Counseling</h3>
            <p>Compassionate one-on-one guidance to move through grief, transition, and awakening with clarity and grace.</p>
            <span class="card-link">Learn more <span aria-hidden="true">→</span></span>
          </a>
          <a href={`${import.meta.env.BASE_URL}consultations/`} class="offer-card reveal">
            <span class="offer-glyph" aria-hidden="true">✵</span>
            <h3>Career &amp; Business Counseling</h3>
            <p>Intuitive insight for decisions, direction, and alignment — bringing your work into harmony with your purpose.</p>
            <span class="card-link">Learn more <span aria-hidden="true">→</span></span>
          </a>
          <a href={`${import.meta.env.BASE_URL}consultations/`} class="offer-card reveal">
            <span class="offer-glyph" aria-hidden="true">⌂</span>
            <h3>House &amp; Property Blessing</h3>
            <p>Energy cleansing and blessing for homes and spaces — clearing what lingers, inviting in light and peace.</p>
            <span class="card-link">Learn more <span aria-hidden="true">→</span></span>
          </a>
          <a href={`${import.meta.env.BASE_URL}consultations/`} class="offer-card reveal">
            <span class="offer-glyph" aria-hidden="true">🐾</span>
            <h3>Animal Communication</h3>
            <p>The animal kingdom speaks. Kim listens — connecting you with the thoughts and feelings of your beloved companions.</p>
            <span class="card-link">Learn more <span aria-hidden="true">→</span></span>
          </a>
        </div>
        <div class="offerings-cta reveal">
          <a href={`${import.meta.env.BASE_URL}request-a-session/`} class="btn btn-glow">Request a Private Session</a>
        </div>
      </div>
    </section>

    <!-- ═══════════════ DR. PEEBLES ═══════════════ -->
    <section class="peebles" id="peebles">
      <div class="peebles-stars" aria-hidden="true"></div>
      <div class="container peebles-grid">
        <div class="peebles-portrait reveal" aria-hidden="true">
          <div class="portrait-ring">
            <div class="portrait-inner">
              <span class="portrait-glyph">✦</span>
              <span class="portrait-caption">Dr. James Martin Peebles<br /><small>1822 – 1922</small></span>
            </div>
          </div>
        </div>
        <div class="peebles-copy reveal">
          <p class="section-kicker">Spirit Communication</p>
          <h2>A voice from beyond the veil: <em>Dr.&nbsp;James Martin Peebles</em></h2>
          <p>
            Kim is renowned for her rare gift as a trance medium — allowing the spirit
            of Dr. James Martin Peebles, a holistic physician and 19th-century leader of
            the Spiritualist movement, to speak directly through her in a deep trance state.
          </p>
          <p>
            Witty, warm, and profoundly wise, Dr. Peebles offers philosophy, healing
            counsel, and answers to your soul's deepest questions — an encounter many
            describe as unlike anything they have ever experienced.
          </p>
          <div class="peebles-links">
            <a href={`${import.meta.env.BASE_URL}spirit-communication/`} class="text-link">About Dr. Peebles <span aria-hidden="true">→</span></a>
            <a href={`${import.meta.env.BASE_URL}spirit-communication/`} class="text-link">Hear audio recordings <span aria-hidden="true">→</span></a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════ MESSAGE FROM KIM ═══════════════ -->
    <section class="message">
      <div class="container message-inner reveal">
        <p class="section-kicker center">A Message from Kim</p>
        <blockquote>
          <p>
            “I invite you to join with me in an exciting adventure of self-discovery.
            If you're reading this now, know that you have been guided to take a giant
            step into a deeper awareness of yourself and of your life. Gather your
            courage and be willing to ask the questions that will lead the way.
            <em>Why are you here? What did you come here to do? Are you on the right path?</em>
          </p>
          <p>
            Allow me the privilege and joy of helping you to remember your greatness.
            May love and light shine upon you always.”
          </p>
          <footer>— <span class="sig">Kim</span></footer>
        </blockquote>
      </div>
    </section>

    <!-- ═══════════════ EVENTS TEASER ═══════════════ -->
    <section class="events" id="events">
      <div class="container events-inner reveal">
        <div>
          <p class="section-kicker">Gather in Spirit</p>
          <h2>Classes, workshops &amp; <em>trance demonstrations</em></h2>
          <p>
            Join Kim for metaphysical lectures, spiritual development classes, and
            live group channeling sessions with Dr. Peebles — in Scottsdale and online.
          </p>
        </div>
        <a href="#" class="btn btn-ghost">Go to Calendar</a>
      </div>
    </section>
  </main>
</Layout>
