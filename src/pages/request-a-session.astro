---
import Layout from "../layouts/Layout.astro";
---
<Layout
  title="Request a Session — Kimberly Dumaine"
  description="Request a private consultation with Kimberly Dumaine — by phone, email, or in person in Scottsdale, Arizona."
>
  <section class="page-hero">
    <div class="container">
      <p class="section-kicker center">By Appointment Only</p>
      <h1>Request a <em>Session</em></h1>
      <p>Reach out by phone or email to schedule your consultation with Kim.</p>
    </div>
  </section>

  <main>
    <section class="page-content">
      <div class="container prose" style="text-align: center;">
        <p>
          Sessions are available in-person in Scottsdale, Arizona, or by phone and online
          for clients nationwide and abroad. Let Kim know which type of consultation
          you&rsquo;re interested in and your preferred dates, and she&rsquo;ll follow up
          to confirm your appointment.
        </p>
        <div class="hero-actions" style="justify-content: center; margin-top: 40px;">
          <a href="mailto:kim@kimdumaine.com" class="btn btn-glow">Email kim@kimdumaine.com</a>
          <a href="tel:+14803428544" class="btn btn-ghost">Call (480) 342-8544</a>
        </div>
      </div>
    </section>
  </main>
</Layout>
