---
const isHome = Astro.url.pathname === import.meta.env.BASE_URL;
---
<header class={`site-nav${isHome ? " nav-animate" : ""}`} id="siteNav">
  <a class="brand" href={import.meta.env.BASE_URL}>
    <span class="brand-mark" aria-hidden="true">✦</span>
    <span class="brand-name">Kimberly Dumaine</span>
  </a>
  <nav aria-label="Primary">
    <ul class="nav-list">
      <li><a href={`${import.meta.env.BASE_URL}about-kim/`} class="nav-link">About Kim</a></li>
      <li class="has-sub">
        <a href={`${import.meta.env.BASE_URL}consultations/`} class="nav-link">Consultations <span class="caret" aria-hidden="true">▾</span></a>
        <ul class="sub-menu">
          <li><a href={`${import.meta.env.BASE_URL}consultations/`}>Life Assessment Sessions</a></li>
          <li><a href={`${import.meta.env.BASE_URL}consultations/`}>Trance Session with Dr.&nbsp;Peebles</a></li>
          <li><a href={`${import.meta.env.BASE_URL}consultations/`}>Spiritual Counseling</a></li>
          <li><a href={`${import.meta.env.BASE_URL}consultations/`}>Career &amp; Business Counseling</a></li>
          <li><a href={`${import.meta.env.BASE_URL}consultations/`}>House &amp; Property Blessing / Energy Cleansing</a></li>
          <li><a href={`${import.meta.env.BASE_URL}consultations/`}>Animal Communication</a></li>
          <li class="sub-cta"><a href={`${import.meta.env.BASE_URL}request-a-session/`}>Request a Private Session</a></li>
        </ul>
      </li>
      <li class="has-sub">
        <a href={`${import.meta.env.BASE_URL}spirit-communication/`} class="nav-link">Spirit Communication <span class="caret" aria-hidden="true">▾</span></a>
        <ul class="sub-menu">
          <li><a href={`${import.meta.env.BASE_URL}spirit-communication/`}>About Dr.&nbsp;Peebles</a></li>
          <li><a href={`${import.meta.env.BASE_URL}spirit-communication/`}>Channeling Dr.&nbsp;Peebles</a></li>
          <li><a href={`${import.meta.env.BASE_URL}spirit-communication/`}>Philosophy of Living</a></li>
          <li><a href={`${import.meta.env.BASE_URL}spirit-communication/`}>Trance Channeling Sessions</a></li>
          <li class="sub-cta"><a href={`${import.meta.env.BASE_URL}request-a-session/`}>Request a Private Session</a></li>
        </ul>
      </li>
      <li><a href={`${import.meta.env.BASE_URL}faqs/`} class="nav-link">FAQs</a></li>
      <li><a href={`${import.meta.env.BASE_URL}testimonials/`} class="nav-link">Testimonials</a></li>
    </ul>
  </nav>
  <a href={`${import.meta.env.BASE_URL}request-a-session/`} class="nav-session-btn">Request a Session</a>
  <button class="nav-toggle" id="navToggle" aria-label="Open menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</header>
